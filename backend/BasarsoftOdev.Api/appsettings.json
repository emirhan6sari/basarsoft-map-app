{
  "Logging": {
    "SlowRequestThresholdMs": 2000,
    "SkipPathPrefixes": [ "/swagger", "/health", "/favicon" ]
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] [{TraceId}] [{UserName}] [{SourceContext}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  },
  "Jwt": {
    "Issuer": "BasarsoftMapApi",
    "Audience": "BasarsoftMapClient",
    "SecretKey": "basarsoft_basarsoft_basarsoft_basarsoft",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 7
  },
  "Map": {
    "ProximityRadiusMeters": 50,
    "BboxMaxResults": 10000,
    "ListMaxResults": 5000
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "AllowedHosts": "*"
}
