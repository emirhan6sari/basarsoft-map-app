# ============================================================================
# .env.example — Frontend için gereken environment variable'ların ÖRNEK listesi
# ----------------------------------------------------------------------------
# Bu dosya repoya commit edilir; geliştirici klonladığında bunu
# .env olarak kopyalayıp kendi değerlerini girer.
#
# Kullanım:
#   cp .env.example .env
#   (sonra .env içindeki değerleri kendi ortamına göre ayarla)
# ============================================================================

# Backend API kök URL'i (sondaki / olmadan)
# Yerel: http://localhost:5226
# Canlı: https://<railway-backend-url>
VITE_API_BASE_URL=http://localhost:5226
